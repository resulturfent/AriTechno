@using AriTechno.Database.Entities
@{
    ViewData["Title"] = "Dashboard v3";
    Layout = "~/Areas/AdminPanel/Views/Shared/_Layout.cshtml";
}
@model List<Category>



<main class="app-main">
    <div class="app-content">
        <div class="container-fluid">
            <div class="card card-primary">
                <div class="card-header">
                    <div class="col-md-10">
                        <h4>Kategori List</h4>
                    </div>

                    <div class="col-md-2 float-right">
                        @Html.ActionLink("EKLE", "Create", "Category", null, new { @class = "btn btn-success float-right" })
                    </div>
                </div>

            </div>
            <div class="container-fluid">
                <div class="row">
                    <div style="margin: 25px auto;">
                        <table id="example" class="table table-striped table-bordered dt-responsive nowrap" cellspacing="0" width="100%">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Kategori Adı</th>
                                    <th>Açıklama</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                               @foreach(var item in Model )
                                {
                                    <tr>
                                        <td>@item.Id</td>
                                        <td>@item.Adi</td>
                                        <td>@item.Aciklama</td>
                                        <td>
                                            <input type="submit" class="btn btn-sn btn-warning" name="name" value="Güncelle" />
                                            <input type="submit" class="btn btn-sn btn-danger" name="name" value="Sil" />
                                        </td>
                                    </tr>

                                }
                            </tbody>
                        </table>

                    </div>

                </div>
            </div>
        </div>
    </div>
</main>
@section Scripts {
    <script src="//code.jquery.com/jquery-1.11.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.13/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.13/js/dataTables.bootstrap.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.1.1/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.1.1/js/responsive.bootstrap.min.js"></script>
    <script src="~/list/listjs.js"></script>
}
